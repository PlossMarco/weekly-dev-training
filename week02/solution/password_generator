"""
Dieses Modul generiert ein zufälliges Passwort, dass n-stellig ist.
"""


import random
import string

def get_length():
    """Diese Funktion fragt den Benutzer nach der Länge des Passwortes und gibt sie zurück"""
    while True:
        try:
            length = int(input("Wie viele Zeichen soll dein neues Passwort haben? "))
            if length < 1:
                print("Bitte gib eine positive Zahl ein!")
            elif length > 20:
                print("Bitte gib eine Zahl zwischen 1 und 20 ein!")
            else:
                return length
        except ValueError:
            print("Bitte gib eine Zahl zwischen 1 und 20 ein!")

def password_generator(length):
    """Diese Funktion generiert ein zufälliges Passwort, dass n-stellig ist."""
    alle_zeichen = string.ascii_letters + string.digits + string.punctuation
    password = "".join(random.choice(alle_zeichen) for _ in range(length))
    print(password)

if __name__ == "__main__":
    length = get_length()
    password_generator(length)

